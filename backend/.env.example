# Neon PostgreSQL — use the asyncpg-compatible URL
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-32-char-secret

# Admin operations (creating tenants via /api/v1/admin/tenants)
ADMIN_SECRET=replace-with-admin-secret

# OpenAI (optional — used by AI router)
OPENAI_API_KEY=sk-...

# Frontend URL for CORS (your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# Notion (tenant notion_token in DB overrides for API; these are for Railway / local parity)
# NOTION_TRANSACTIONS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NOTION_SYNC_ALLOW_EMPTY_MODEL=0

# Google OAuth (Sheets/Drive readonly). Registered at console.cloud.google.com:
#   APIs & Services → Enable APIs → Google Sheets API + Google Drive API
#   Credentials → OAuth 2.0 Client ID (Web application)
#   Authorized redirect URIs: <GOOGLE_REDIRECT_URI>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/v1/google/callback

# Fernet key for tenant_sources.credentials encryption (recommended in prod).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_FERNET_KEY=

# AI Аналитик (Claude / Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
AI_ANALYST_MODEL=claude-sonnet-4-6
AI_REPORT_MODEL=claude-opus-4-8

# Планировщик (APScheduler)
ENABLE_SCHEDULER=1

# Agent Watcher (проактивный агент — ежедневный скан + проверка событий)
# Зависит от ENABLE_SCHEDULER=1 и ANTHROPIC_API_KEY
AGENT_WATCHER_ENABLED=1

# Ежедневный сбор KPI-метрик из Onlymonster → chatter_kpi_daily (04:00 UTC)
# Зависит от ENABLE_SCHEDULER=1 и onlymonster_key в настройках тенанта
ENABLE_KPI_DAILY=0

# Зависит от ENABLE_SCHEDULER=1. HOLD-review cron 05:00 UTC + ручной триггер /run-review-now
ENABLE_ADMIN_KPI=0

# Миграции: из каталога backend — alembic upgrade head (DATABASE_URL обязателен; для Alembic допустим postgresql+asyncpg — env.py приведёт к sync)
