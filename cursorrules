## Backend

### 1. Google OAuth — routers/auth_google.py (новый файл)

```python
from fastapi import APIRouter, Depends, HTTPException
from fastapi.responses import RedirectResponse
import httpx
import os
from dependencies import get_current_tenant, get_db
from models import Tenant, TenantSource
from sqlalchemy.ext.asyncio import AsyncSession

router = APIRouter(prefix="/api/v1/google", tags=["google"])

GOOGLE_CLIENT_ID = os.getenv("GOOGLE_CLIENT_ID")
GOOGLE_CLIENT_SECRET = os.getenv("GOOGLE_CLIENT_SECRET")
GOOGLE_REDIRECT_URI = os.getenv("GOOGLE_REDIRECT_URI")  # https://api.flowof.io/api/v1/google/callback

SCOPES = "https://www.googleapis.com/auth/spreadsheets.readonly https://www.googleapis.com/auth/drive.readonly"

@router.get("/auth-url")
async def get_google_auth_url(tenant: Tenant = Depends(get_current_tenant)):
    """Вернуть URL для Google OAuth."""
    url = (
        "https://accounts.google.com/o/oauth2/v2/auth"
        f"?client_id={GOOGLE_CLIENT_ID}"
        f"&redirect_uri={GOOGLE_REDIRECT_URI}"
        f"&response_type=code"
        f"&scope={SCOPES}"
        f"&access_type=offline"
        f"&prompt=consent"
        f"&state={tenant.id}"  # передаём tenant_id чтобы знать кому сохранить токен
    )
    return {"url": url}

@router.get("/callback")
async def google_callback(
    code: str,
    state: str,  # tenant_id
    db: AsyncSession = Depends(get_db)
):
    """Google редиректит сюда после авторизации."""
    # Обменять code на токены
    async with httpx.AsyncClient() as client:
        response = await client.post(
            "https://oauth2.googleapis.com/token",
            data={
                "code": code,
                "client_id": GOOGLE_CLIENT_ID,
                "client_secret": GOOGLE_CLIENT_SECRET,
                "redirect_uri": GOOGLE_REDIRECT_URI,
                "grant_type": "authorization_code"
            }
        )

    tokens = response.json()
    if "error" in tokens:
        raise HTTPException(status_code=400, detail=tokens["error"])

    access_token = tokens["access_token"]
    refresh_token = tokens.get("refresh_token")
    tenant_id = int(state)

    # Сохранить токены в tenant_sources
    source = TenantSource(
        tenant_id=tenant_id,
        source_type="google_sheets",
        credentials={
            "access_token": access_token,
            "refresh_token": refresh_token
        },
        active=False  # станет True после выбора таблицы
    )
    db.add(source)
    await db.commit()

    # Редиректим обратно на фронтенд с флагом успеха
    frontend_url = os.getenv("FRONTEND_URL", "https://flowof.io")
    return RedirectResponse(f"{frontend_url}/onboarding?google_connected=true")


@router.get("/spreadsheets")
async def list_spreadsheets(tenant: Tenant = Depends(get_current_tenant)):
    """Получить список Google Sheets пользователя."""
    access_token = await get_google_token(tenant.id)

    async with httpx.AsyncClient() as client:
        response = await client.get(
            "https://www.googleapis.com/drive/v3/files",
            headers={"Authorization": f"Bearer {access_token}"},
            params={
                "q": "mimeType='application/vnd.google-apps.spreadsheet'",
                "fields": "files(id,name,modifiedTime)",
                "orderBy": "modifiedTime desc",
                "pageSize": 20
            }
        )

    files = response.json().get("files", [])
    return {"spreadsheets": files}


@router.get("/sheets/{spreadsheet_id}")
async def list_sheets(
    spreadsheet_id: str,
    tenant: Tenant = Depends(get_current_tenant)
):
    """Получить список листов внутри таблицы."""
    access_token = await get_google_token(tenant.id)

    async with httpx.AsyncClient() as client:
        response = await client.get(
            f"https://sheets.googleapis.com/v4/spreadsheets/{spreadsheet_id}",
            headers={"Authorization": f"Bearer {access_token}"},
            params={"fields": "sheets.properties"}
        )

    sheets = response.json().get("sheets", [])
    return {
        "sheets": [
            {"id": s["properties"]["sheetId"], "name": s["properties"]["title"]}
            for s in sheets
        ]
    }
```

