```python
from openai import AsyncOpenAI
import json
import pandas as pd
import io
import logging

logger = logging.getLogger(__name__)

class AIImporter:
    """
    Принимает CSV любой структуры.
    Использует GPT-4o чтобы привести к стандарту FlowOF.
    """

    SCHEMA = {
        "date": "дата транзакции или смены (YYYY-MM-DD)",
        "model": "имя или ник модели/исполнителя",
        "chatter": "имя или ник чаттера/менеджера",
        "amount": "сумма выручки в деньгах (число без символов валюты)",
        "shift_id": "номер или ID смены (опционально, может отсутствовать)"
    }

    def __init__(self, openai_key: str):
        self.client = AsyncOpenAI(api_key=openai_key)

    async def process(self, csv_content: str) -> dict:
        """
        Основной метод.
        Принимает CSV строку, возвращает нормализованные данные.
        """
        # Прочитать CSV чтобы узнать колонки и количество строк
        df = pd.read_csv(io.StringIO(csv_content))
        original_columns = df.columns.tolist()
        total_rows = len(df)

        logger.info(f"AIImporter: {total_rows} строк, колонки: {original_columns}")

        # Если таблица большая — обрабатываем батчами по 200 строк
        if total_rows > 200:
            rows = await self._process_in_batches(df)
        else:
            rows = await self._process_chunk(csv_content)

        # Определить маппинг (для отображения пользователю)
        mapping = await self._detect_mapping(original_columns)

        return {
            "rows": rows,
            "total": len(rows),
            "original_columns": original_columns,
            "mapping": mapping,
            "warnings": self._find_warnings(rows, total_rows)
        }

    async def _process_chunk(self, csv_content: str) -> list[dict]:
        """Обработать один кусок CSV через GPT-4o."""

        # Ограничим размер чтобы не превышать контекст
        lines = csv_content.split('\n')
        if len(lines) > 300:
            csv_content = '\n'.join(lines[:300])

        prompt = f"""Ты помощник по импорту данных для FlowOF — системы аналитики OF-агентств.

Вот CSV таблица агентства:
```
{csv_content}
```

Наша стандартная схема транзакций:
{json.dumps(self.SCHEMA, ensure_ascii=False, indent=2)}

Задача:
1. Найди колонки которые соответствуют нашей схеме (названия могут быть на любом языке)
2. Преобразуй КАЖДУЮ строку данных в наш формат
3. Очисти суммы: убери $, руб, €, пробелы, запятые → оставь только число (например "1 500,50 $" → 1500.50)
4. Нормализуй даты → формат YYYY-MM-DD (например "01.04.2026" → "2026-04-01")
5. Если строка не содержит транзакцию (итоги, заголовки, пустые) — пропусти её
6. Верни ТОЛЬКО валидный JSON массив без пояснений, markdown и текста:

[
  {{"date": "2026-04-01", "model": "Anna", "chatter": "Max", "amount": 150.0, "shift_id": "1"}},
  ...
]

Если поле не найдено в таблице — ставь null.
Не придумывай данные которых нет в таблице."""

        response = await self.client.chat.completions.create(
            model="gpt-4o",
            messages=[{"role": "user", "content": prompt}],
            temperature=0,  # максимальная точность
            response_format={"type": "json_object"}
        )

        content = response.choices[0].message.content

        # GPT иногда возвращает {"data": [...]} вместо [...]
        parsed = json.loads(content)
        if isinstance(parsed, list):
            return parsed
        if isinstance(parsed, dict):
            # найти первый список в ответе
            for value in parsed.values():
                if isinstance(value, list):
                    return value

        return []

    async def _process_in_batches(self, df: pd.DataFrame) -> list[dict]:
        """Обработать большую таблицу батчами."""
        all_rows = []
        batch_size = 150
        header = df.columns.tolist()

        for i in range(0, len(df), batch_size):
            batch_df = df.iloc[i:i + batch_size]
            batch_csv = batch_df.to_csv(index=False)
            batch_rows = await self._process_chunk(batch_csv)
            all_rows.extend(batch_rows)
            logger.info(f"Батч {i//batch_size + 1}: получено {len(batch_rows)} строк")

        return all_rows

    async def _detect_mapping(self, columns: list[str]) -> dict:
        """Определить маппинг колонок для отображения пользователю."""
        prompt = f"""Колонки таблицы: {columns}

Наша схема: date, model, chatter, amount, shift_id

Верни JSON маппинг (колонка_пользователя → наше_поле):
{{"Дата выхода": "date", "Ник модели": "model", ...}}

Только те колонки которые явно соответствуют. ТОЛЬКО JSON."""

        response = await self.client.chat.completions.create(
            model="gpt-4o-mini",  # для маппинга хватит mini
            messages=[{"role": "user", "content": prompt}],
            temperature=0,
            response_format={"type": "json_object"}
        )

        try:
            return json.loads(response.choices[0].message.content)
        except Exception:
            return {}

    def _find_warnings(self, rows: list[dict], original_count: int) -> list[str]:
        """Предупреждения для пользователя."""
        warnings = []
        imported = len(rows)

        if imported < original_count * 0.5:
            warnings.append(
                f"Распознано только {imported} из {original_count} строк. "
                f"Возможно таблица содержит нестандартный формат."
            )

        no_amount = sum(1 for r in rows if not r.get("amount"))
        if no_amount > 0:
            warnings.append(f"{no_amount} строк без суммы — проверь колонку с выручкой.")

        no_model = sum(1 for r in rows if not r.get("model"))
        if no_model > imported * 0.3:
            warnings.append(f"У {no_model} строк не определена модель.")

        return warnings
