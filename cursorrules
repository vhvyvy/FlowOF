import httpx

class GoogleSheetsService:
    def __init__(self, access_token: str):
        self.access_token = access_token
        self.headers = {"Authorization": f"Bearer {access_token}"}

    async def download_as_csv(self, spreadsheet_id: str, sheet_name: str) -> str:
        """Скачать лист как CSV строку."""
        # Получить данные через Sheets API
        url = f"https://sheets.googleapis.com/v4/spreadsheets/{spreadsheet_id}/values/{sheet_name}"

        async with httpx.AsyncClient() as client:
            response = await client.get(url, headers=self.headers)

        data = response.json()
        rows = data.get("values", [])

        if not rows:
            return ""

        # Конвертировать в CSV
        import csv
        import io
        output = io.StringIO()
        writer = csv.writer(output)
        for row in rows:
            writer.writerow(row)

        return output.getvalue()

    async def refresh_token(self, refresh_token: str) -> str:
        """Обновить access_token если истёк."""
        import os
        async with httpx.AsyncClient() as client:
            response = await client.post(
                "https://oauth2.googleapis.com/token",
                data={
                    "refresh_token": refresh_token,
                    "client_id": os.getenv("GOOGLE_CLIENT_ID"),
                    "client_secret": os.getenv("GOOGLE_CLIENT_SECRET"),
                    "grant_type": "refresh_token"
                }
            )
        return response.json().get("access_token")
