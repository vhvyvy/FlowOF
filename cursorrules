```python
@scheduler.scheduled_job("cron", month="3,6,9,12", day="last", hour=23, minute=55)
async def auto_close_season():
    async with AsyncSessionLocal() as db:
        active_seasons = await db.execute(
            "SELECT id FROM mmr_seasons WHERE is_active = TRUE AND end_date = CURRENT_DATE"
        )
        for season in active_seasons:
            try:
                service = SeasonService()
                await service.close_season(season.id, db)
