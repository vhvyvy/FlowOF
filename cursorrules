        raise HTTPException(404)

    # Проверить что у чаттера ещё нет привязанного user
    existing = await db.execute(
        "SELECT id FROM users WHERE chatter_id = :cid",
        {"cid": chatter_id}
    )
    if existing.scalar_one_or_none():
        raise HTTPException(400, "У этого чаттера уже есть аккаунт")

    # Создать инвайт
    invite = ChatterInvite(
        tenant_id=owner.tenant_id,
        chatter_id=chatter_id,
        token=secrets.token_urlsafe(32),
        expires_at=datetime.utcnow() + timedelta(days=7),
        created_by_user_id=owner.id
    )
    db.add(invite)
    await db.commit()
    await db.refresh(invite)

    invite_url = f"{os.getenv('FRONTEND_URL')}/join?token={invite.token}"

    return {
        "invite_id": invite.id,
        "token": invite.token,
        "url": invite_url,
        "expires_at": invite.expires_at,
        "chatter_name": chatter.name
    }

