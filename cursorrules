## Backend — сервис расчёта MMR

```python
# services/mmr_service.py

from datetime import date, datetime, timedelta
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select
import logging

logger = logging.getLogger(__name__)

LEAGUE_THRESHOLDS = [
    ("bronze_iii", 0),
    ("bronze_ii", 100),
    ("bronze_i", 200),
    ("silver_iii", 300),
    ("silver_ii", 450),
    ("silver_i", 600),
    ("gold_iii", 800),
    ("gold_ii", 1000),
    ("gold_i", 1250),
    ("platinum_iii", 1500),
    ("platinum_ii", 1800),
    ("platinum_i", 2100),
    ("diamond_iii", 2500),
    ("diamond_ii", 3000),
    ("diamond_i", 3500),
    ("master", 4500),
    ("grandmaster", 6000),
]

def mmr_to_league(mmr: int) -> str:
    """Из числа MMR определить лигу."""
    league = LEAGUE_THRESHOLDS[0][0]
    for name, threshold in LEAGUE_THRESHOLDS:
        if mmr >= threshold:
            league = name
        else:
            break
    return league


class MMRService:
    """
    Расчёт MMR-событий за день для всех чаттеров tenant.
    Запускается ежедневно через APScheduler.
    """

    def __init__(self, db: AsyncSession):
        self.db = db

    async def process_day(self, tenant_id: int, target_date: date):
        """Главный метод — обработать один день для tenant."""
        # 1. Получить настройки MMR
        settings = await self._get_settings(tenant_id)

        # 2. Получить активный сезон (создать если нет)
        season = await self._get_or_create_active_season(tenant_id, target_date)

        # 3. Финансовая часть — за каждый день, каждый чаттер, каждая смена
        await self._process_finance(tenant_id, season, settings, target_date)

        # 4. KPI часть — если включена и есть данные
        if settings.kpi_enabled:
            await self._process_kpi(tenant_id, season, settings, target_date)

        # 5. Пересчитать current_mmr и лигу для всех чаттеров
        await self._recalculate_mmr_state(tenant_id, season)

        await self.db.commit()
        logger.info(f"MMR обработан: tenant={tenant_id}, date={target_date}")

    async def _process_finance(self, tenant_id, season, settings, target_date):
        """Для каждой смены каждого чаттера — сравнить выручку с планом."""
        # Получить все транзакции чаттеров за день, сгруппированные по chatter_id + shift_id + model_id
        result = await self.db.execute(
            """
            SELECT t.chatter_id, t.shift_id, t.model_id, SUM(t.amount) AS revenue
            FROM transactions t
            WHERE t.tenant_id = :tid
              AND DATE(t.date) = :date
              AND t.chatter_id IS NOT NULL
            GROUP BY t.chatter_id, t.shift_id, t.model_id
            """,
            {"tid": tenant_id, "date": target_date}
        )
        day_groups = list(result.mappings())

        # Получить число смен в агентстве
        shifts_count_result = await self.db.execute(
            "SELECT COUNT(*) FROM shifts_catalog WHERE tenant_id = :tid AND active = TRUE",
            {"tid": tenant_id}
        )
        shifts_count = shifts_count_result.scalar() or 1

        # Дней в месяце target_date
        days_in_month = self._days_in_month(target_date)

        for row in day_groups:
            # Дневной план для этой модели/смены
            plan_result = await self.db.execute(
                "SELECT plan_amount FROM plans WHERE tenant_id = :tid AND model_id = :mid AND month = :m AND year = :y",
                {"tid": tenant_id, "mid": row["model_id"], "m": target_date.month, "y": target_date.year}
            )
            plan_row = plan_result.mappings().first()
            if not plan_row or not plan_row["plan_amount"]:
                continue

            monthly_plan = float(plan_row["plan_amount"])
            daily_plan = monthly_plan / shifts_count / days_in_month
            revenue = float(row["revenue"])
            performance = revenue / daily_plan if daily_plan > 0 else 0

            # Определить категорию
            if performance >= settings.fin_overperform_threshold:
                category = "overperform"
                points = settings.fin_overperform_points
            elif performance >= settings.fin_underperform_threshold:
                category = "perform"
                points = settings.fin_perform_points
            else:
                category = "underperform"
                points = settings.fin_underperform_points

            description = f"План ${daily_plan:.0f}, выручка ${revenue:.0f} ({performance*100:.0f}%)"

            await self._create_event(
                tenant_id=tenant_id,
                chatter_id=row["chatter_id"],
                season_id=season.id,
                event_date=target_date,
                event_type="finance",
                category=category,
                points=points,
                description=description,
                shift_id=row["shift_id"],
                model_id=row["model_id"]
            )

        # Отдельно — пустые смены (чаттер был назначен но 0 транзакций)
        # Здесь нужна логика учёта смен чаттера. Если в продукте уже есть
        # таблица назначений чаттера на смену — использовать её.
        # Если нет — пропустить этот шаг (минусы за пустые смены пока не считаем).

    async def _process_kpi(self, tenant_id, season, settings, target_date):
        """KPI-метрики из Onlymonster — сравнение с личным средним чаттера."""
        # Получить дневные метрики из Onlymonster service
        # (предполагается что сервис уже умеет отдавать метрики на дату)
        from services.onlymonster import OnlymonsterService

        tenant_result = await self.db.execute(
            "SELECT onlymonster_key, onlymonster_account_ids FROM tenants WHERE id = :tid",
            {"tid": tenant_id}
        )
        tenant = tenant_result.mappings().first()
        if not tenant or not tenant["onlymonster_key"]:
            return

        om = OnlymonsterService(tenant["onlymonster_key"], tenant["onlymonster_account_ids"])
        daily_metrics = await om.get_daily_metrics(target_date)
        # daily_metrics: [{chatter_name, ppv_open_rate, rpc, conversion}, ...]

        for metric in daily_metrics:
            # Найти chatter_id по имени
            chatter_result = await self.db.execute(
                "SELECT id FROM chatters WHERE tenant_id = :tid AND name = :name",
                {"tid": tenant_id, "name": metric["chatter_name"]}
            )
            chatter_row = chatter_result.mappings().first()
            if not chatter_row:
                continue
            chatter_id = chatter_row["id"]

            # Личный средний или агентский (если калибровка не завершена)
            mmr_row = await self.db.execute(
                "SELECT calibration_complete FROM chatter_mmr WHERE tenant_id = :tid AND chatter_id = :cid AND season_id = :sid",
                {"tid": tenant_id, "cid": chatter_id, "sid": season.id}
            )
            mmr_state = mmr_row.mappings().first()
            use_personal = mmr_state and mmr_state["calibration_complete"]

            # Сравнить три метрики
            for key in ["ppv_open_rate", "rpc", "conversion"]:
                value = metric.get(key)
                if value is None:
                    continue

                avg = await self._get_avg_metric(
                    tenant_id, chatter_id, key, personal=use_personal
                )
                if not avg:
                    continue

                if value > avg * settings.kpi_threshold_high:
                    category = "kpi_high"
                    points = settings.kpi_high_points
                    description = f"{key.upper()}: {value:.2f} (среднее {avg:.2f}, +{(value/avg-1)*100:.0f}%)"
                elif value < avg * settings.kpi_threshold_low:
                    category = "kpi_low"
                    points = settings.kpi_low_points
                    description = f"{key.upper()}: {value:.2f} (среднее {avg:.2f}, -{(1-value/avg)*100:.0f}%)"
                else:
                    continue  # в норме, событий не создаём

                await self._create_event(
                    tenant_id=tenant_id,
                    chatter_id=chatter_id,
                    season_id=season.id,
                    event_date=target_date,
                    event_type="kpi",
                    category=category,
                    points=points,
                    description=description
                )

    async def _recalculate_mmr_state(self, tenant_id, season):
        """Пересчитать current_mmr, лигу, дни активности для всех чаттеров."""
        # Получить всех чаттеров с событиями в этом сезоне
        result = await self.db.execute(
            """
            SELECT chatter_id,
                   SUM(points) AS total_mmr,
                   COUNT(DISTINCT event_date) AS active_days
            FROM mmr_events
            WHERE tenant_id = :tid AND season_id = :sid
            GROUP BY chatter_id
            """,
            {"tid": tenant_id, "sid": season.id}
        )

        settings = await self._get_settings(tenant_id)

        for row in result.mappings():
            total = max(0, row["total_mmr"])  # MMR не может быть отрицательным
            active_days = row["active_days"]
            calibrated = active_days >= settings.calibration_days
            league = mmr_to_league(total) if calibrated else None

            # UPSERT в chatter_mmr
            await self.db.execute(
                """
                INSERT INTO chatter_mmr (tenant_id, chatter_id, season_id, current_mmr, peak_mmr, current_league, calibration_complete, days_active)
                VALUES (:tid, :cid, :sid, :mmr, :mmr, :league, :calib, :days)
                ON CONFLICT (tenant_id, chatter_id, season_id) DO UPDATE
                SET current_mmr = :mmr,
                    peak_mmr = GREATEST(chatter_mmr.peak_mmr, :mmr),
                    current_league = :league,
                    calibration_complete = :calib,
