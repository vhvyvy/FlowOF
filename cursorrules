    token: str
    email: str
    password: str
    full_name: str

@router.post("/accept")
async def accept_invite(
    data: AcceptInviteRequest,
    db: AsyncSession = Depends(get_db)
):
    """Чаттер принимает инвайт и создаёт свой аккаунт."""
    # Найти инвайт
    invite = await db.execute(
        "SELECT * FROM chatter_invites WHERE token = :token",
        {"token": data.token}
    )
    invite = invite.mappings().first()
    if not invite or invite["used"] or invite["expires_at"] < datetime.utcnow():
        raise HTTPException(400, "Инвайт недействителен")

    # Проверить что email не занят
    existing = await db.execute(
        "SELECT id FROM users WHERE email = :email",
        {"email": data.email}
    )
    if existing.scalar_one_or_none():
        raise HTTPException(400, "Email уже зарегистрирован")

    # Создать user с ролью chatter
    user = User(
        tenant_id=invite["tenant_id"],
        email=data.email,
        hashed_password=hash_password(data.password),
        role="chatter",
        full_name=data.full_name,
        chatter_id=invite["chatter_id"]
    )
    db.add(user)
    await db.flush()

    # Пометить инвайт использованным
    await db.execute(
        "UPDATE chatter_invites SET used = TRUE, used_at = NOW() WHERE id = :iid",
        {"iid": invite["id"]}
    )
    await db.commit()
    await db.refresh(user)

    # Сразу выдать токен
    token = create_access_token(user.id, user.tenant_id, "chatter", user.email)
    return {"access_token": token, "token_type": "bearer", "role": "chatter"}
