# при импорте — функция матчинга имени со справочником
async def resolve_model_id(name: str, tenant_id: int, db) -> int:
    """Найти модель по имени или создать новую."""
    if not name:
        return None
    result = await db.execute(
        select(Model).where(Model.tenant_id == tenant_id, Model.name == name)
    )
    model = result.scalar_one_or_none()
    if model:
        return model.id
    # создать новую
    model = Model(tenant_id=tenant_id, name=name)
    db.add(model)
    await db.flush()
    return model.id

# аналогично resolve_chatter_id, resolve_shift_id
