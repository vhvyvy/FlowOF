# routers/entries.py — новый файл
from fastapi import APIRouter, Depends, HTTPException, Query
from sqlalchemy import select, delete
from sqlalchemy.ext.asyncio import AsyncSession
from pydantic import BaseModel
from datetime import date
from dependencies import get_db, get_current_tenant
from models import Tenant, Transaction, Expense

router = APIRouter(prefix="/api/v1/entries", tags=["entries"])

class TransactionCreate(BaseModel):
    date: date
    model_id: int
    chatter_id: int
    shift_id: int | None = None
    amount: float

class ExpenseCreate(BaseModel):
    date: date
    category_id: int
    amount: float
    model_id: int | None = None      # опционально
    description: str | None = None

# --- ТРАНЗАКЦИИ ---
@router.post("/transactions")
async def create_transaction(
    data: TransactionCreate,
    tenant: Tenant = Depends(get_current_tenant),
    db: AsyncSession = Depends(get_db)
):
    tx = Transaction(
        tenant_id=tenant.id,
        date=data.date,
        model_id=data.model_id,
        chatter_id=data.chatter_id,
        shift_id=data.shift_id,
        amount=data.amount,
        source="manual"
    )
    db.add(tx)
    await db.commit()
    await db.refresh(tx)
    return {"id": tx.id, "success": True}

@router.get("/transactions")
async def list_transactions(
    month: int = Query(...),
    year: int = Query(...),
    tenant: Tenant = Depends(get_current_tenant),
    db: AsyncSession = Depends(get_db)
):
    """Список транзакций за месяц с именами из справочников (JOIN)."""
    query = """
        SELECT t.id, t.date, t.amount, t.shift_id,
               m.name AS model_name, c.name AS chatter_name, s.name AS shift_name
        FROM transactions t
        LEFT JOIN models m ON t.model_id = m.id
        LEFT JOIN chatters c ON t.chatter_id = c.id
        LEFT JOIN shifts_catalog s ON t.shift_id = s.id
        WHERE t.tenant_id = :tid
          AND EXTRACT(MONTH FROM t.date) = :month
          AND EXTRACT(YEAR FROM t.date) = :year
        ORDER BY t.date DESC, t.id DESC
    """
    result = await db.execute(query, {"tid": tenant.id, "month": month, "year": year})
    return {"items": [dict(r) for r in result.mappings()]}

@router.put("/transactions/{tx_id}")
async def update_transaction(
    tx_id: int,
    data: TransactionCreate,
    tenant: Tenant = Depends(get_current_tenant),
    db: AsyncSession = Depends(get_db)
):
    tx = await db.get(Transaction, tx_id)
    if not tx or tx.tenant_id != tenant.id:
        raise HTTPException(404)
    tx.date = data.date
    tx.model_id = data.model_id
    tx.chatter_id = data.chatter_id
    tx.shift_id = data.shift_id
    tx.amount = data.amount
    await db.commit()
    return {"success": True}

@router.delete("/transactions/{tx_id}")
async def delete_transaction(
    tx_id: int,
    tenant: Tenant = Depends(get_current_tenant),
    db: AsyncSession = Depends(get_db)
):
    tx = await db.get(Transaction, tx_id)
    if not tx or tx.tenant_id != tenant.id:
        raise HTTPException(404)
    await db.delete(tx)
    await db.commit()
    return {"success": True}

