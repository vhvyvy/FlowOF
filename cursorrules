    access_token = await get_google_token(tenant.id, db)
    sheets_service = GoogleSheetsService(access_token)
    csv_content = await sheets_service.download_as_csv(spreadsheet_id, sheet_name)

    importer = AIImporter(openai_key=tenant.openai_key or os.getenv("OPENAI_API_KEY"))
    result = await importer.process(csv_content)

    # INSERT в БД
    imported = 0
    skipped = 0
    for row in result["rows"]:
        try:
            await db.execute(
                """
                INSERT INTO transactions (tenant_id, date, model, chatter, amount, shift_id)
                VALUES (:tenant_id, :date, :model, :chatter, :amount, :shift_id)
                ON CONFLICT DO NOTHING
                """,
