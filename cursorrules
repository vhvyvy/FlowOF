    db: AsyncSession = Depends(get_db)
):
    """
    Скачать Google Sheet, прогнать через AI, вернуть превью.
    """
    try:
        # 1. Получить токен
        access_token = await get_google_token(tenant.id, db)

        # 2. Скачать таблицу как CSV
        sheets_service = GoogleSheetsService(access_token)
        csv_content = await sheets_service.download_as_csv(spreadsheet_id, sheet_name)

        # 3. Прогнать через AI
        importer = AIImporter(openai_key=tenant.openai_key or os.getenv("OPENAI_API_KEY"))
        result = await importer.process(csv_content)

        # 4. Сохранить конфиг источника
        await save_source_config(tenant.id, spreadsheet_id, sheet_name, db)

        return {
            "preview": result["rows"][:10],        # первые 10 строк
            "total_rows": result["total"],
            "columns_detected": result["original_columns"],
            "mapping_used": result["mapping"],
            "warnings": result["warnings"]          # строки которые не распознались
        }

    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Ошибка импорта: {str(e)}")


@router.post("/google-sheets/confirm")
async def confirm_google_sheets_import(
    spreadsheet_id: str,
    sheet_name: str,
    tenant: Tenant = Depends(get_current_tenant),
    db: AsyncSession = Depends(get_db)
):
